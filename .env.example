# Backend environment variables for Render or local development.
# Copy this file to .env locally. Do not commit real secrets.

# Runtime
NODE_ENV=development
PORT=5000

# MongoDB connection string.
# Render production should set this to your MongoDB Atlas URI.
MONGODB_URI=

# Legacy compatibility only. Prefer MONGODB_URI for new deployments.
MONGO_URI=

# Auth/session secrets. Use long random values in production.
JWT_SECRET=
ADMIN_TOKEN=
# Password accepted by protected admin routes.
# Set this in Render. Use the same value when logging in at /admin.
ADMIN_PASSWORD=

# Frontend URLs used for CORS.
# FRONTEND_URL/CLIENT_URL can be a single local or production frontend URL.
FRONTEND_URL=https://support-kindness.vercel.app
CLIENT_URL=http://localhost:5173

# Comma-separated list of allowed browser origins.
# Localhost and *.vercel.app preview origins are also allowed automatically.
ALLOWED_ORIGINS=https://support-kindness.vercel.app,http://localhost:5173,http://127.0.0.1:5173

# Public payment/support identifier used by backend settings fallback.
UPI_ID=carecontribution@upi

# Email/OTP settings. Leave blank unless email or OTP features are enabled.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=

# Payment provider settings. Leave blank unless payment integrations are enabled.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Cloud upload settings. Leave blank unless Cloudinary uploads are enabled.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
